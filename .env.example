# --- Required (Slack) ---
SLACK_BOT_TOKEN=xoxb-REPLACE-ME
SLACK_SIGNING_SECRET=REPLACE-ME

# --- LLM Provider ---
# Choose "openai" or "ollama" (default: openai)
LLM_PROVIDER=ollama

# --- OpenAI (used when LLM_PROVIDER=openai) ---
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o

# --- Ollama (used when LLM_PROVIDER=ollama) ---
# Ollama API base URL (default: http://localhost:11434/v1)
OLLAMA_BASE_URL=http://localhost:11434/v1
# Ollama model name (default: llama3)
OLLAMA_MODEL=qwen3:4b

# --- Optional (Slack) ---
# Slack app-level token (set this to use Socket Mode instead of HTTP)
SLACK_APP_TOKEN=xapp-REPLACE-ME

# Slack port for HTTP mode (default 3000)
SLACK_PORT=3000

# System prompt for the AI assistant
SYSTEM_PROMPT=You are a helpful infrastructure automation assistant. You can query vRealize Operations Manager (vROps) to find resources, get their properties, create resources, push properties and events, and discover vCenter and NSX-T managers. Always respond with a proper tool call when appropriate.

# Max conversation turns kept per conversation (default 50)
MAX_CONVERSATION_TURNS=50

# --- vROps (for vROps API actions) ---
VROPS_SERVER=
VROPS_USERNAME=
VROPS_PASSWORD=
VROPS_AUTH_SOURCE=Local

# Log level: DEBUG, INFO, WARN, ERROR (default INFO)
LOG_LEVEL=INFO
