# --- Required (Slack) ---
SLACK_BOT_TOKEN=xoxb-REPLACE-ME
SLACK_SIGNING_SECRET=REPLACE-ME

# --- LLM Provider ---
# Choose "openai", "ollama", or "anthropic" (default: openai)
LLM_PROVIDER=ollama

# --- OpenAI (used when LLM_PROVIDER=openai) ---
OPENAI_API_KEY=sk-REPLACE-ME
OPENAI_MODEL=gpt-4o

# --- Anthropic / Claude (used when LLM_PROVIDER=anthropic) ---
ANTHROPIC_API_KEY=sk-ant-REPLACE-ME
ANTHROPIC_MODEL=claude-opus-4-8

# --- Ollama (used when LLM_PROVIDER=ollama) ---
# Ollama API base URL (default: http://localhost:11434/v1)
OLLAMA_BASE_URL=http://localhost:11434/v1
# Ollama model name (default: llama3). qwen3:* are "thinking" models.
OLLAMA_MODEL=qwen3:4b

# Force thinking-model handling (strip <think>...</think>, expect empty content
# after tool calls). "auto" detects qwen/think/deepseek-r1 by name. Values: auto|true|false
IS_THINKING_MODEL=auto

# --- Optional (Slack) ---
# Slack app-level token (set this to use Socket Mode instead of HTTP)
SLACK_APP_TOKEN=xapp-REPLACE-ME

# Slack port for HTTP mode (default 3000)
SLACK_PORT=3000

# System prompt for the AI assistant (grounding rules baked in by default; only
# override if you know what you're doing).
# SYSTEM_PROMPT=

# Max conversation turns kept per conversation (default 50)
MAX_CONVERSATION_TURNS=50

# --- LLM guardrails ---
# Max tokens the model may generate per reply (default 800)
MAX_OUTPUT_TOKENS=800
# Per-request timeout in seconds (default 60)
REQUEST_TIMEOUT_S=60
# Max tool-call rounds per user message before forcing a text answer (default 5)
MAX_TOOL_ITERATIONS=5

# --- vROps (for vROps API actions) ---
VROPS_SERVER=
VROPS_USERNAME=
VROPS_PASSWORD=
VROPS_AUTH_SOURCE=Local

# Optional: path to a JSON file mapping physical sites to vROps Datacenter names,
# used to scope fleet reports (cluster capacity / oversized VMs) by location. Example:
#   {"Madrid": ["dc-mad-01", "dc-mad-02"], "Frankfurt": ["dc-fra-01"]}
VROPS_SITE_MAP_FILE=

# Log level: DEBUG, INFO, WARN, ERROR (default INFO)
LOG_LEVEL=INFO
